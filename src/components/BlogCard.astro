---
type Props = {
  slug: string;
  title: string;
  description: string;
  cover?: string;
  pubDate: Date;
  tags: string[];
};
const { slug, title, description, cover, pubDate, tags } = Astro.props;
const formatted = new Intl.DateTimeFormat('pl-PL', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(pubDate);
---
<a href={`/blog/${slug}`} class="group block">
  {cover && (
    <div class="aspect-[16/10] overflow-hidden rounded-lg bg-line">
      <img
        src={cover}
        alt=""
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
      />
    </div>
  )}
  <div class="mt-4">
    <div class="eyebrow">{formatted}{tags.length > 0 && ` · ${tags.join(', ')}`}</div>
    <h3 class="mt-2 font-display font-bold text-2xl tracking-tight group-hover:text-accent transition">{title}</h3>
    <p class="mt-2 text-muted leading-relaxed">{description}</p>
    <div class="mt-3 text-sm font-medium text-accent group-hover:text-accent-deep">Czytaj →</div>
  </div>
</a>
