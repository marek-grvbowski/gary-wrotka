---
---
<div
  data-drawer
  class="fixed inset-0 z-40 hidden"
  aria-hidden="true"
>
  <div data-drawer-backdrop class="absolute inset-0 bg-ink/40"></div>
  <aside
    class="absolute top-0 right-0 h-full w-full sm:w-[420px] bg-paper shadow-2xl flex flex-col"
    role="dialog"
    aria-label="Koszyk"
  >
    <div class="flex items-center justify-between px-6 py-5 border-b border-line">
      <div>
        <div class="eyebrow">Koszyk</div>
        <div class="font-display font-bold text-xl mt-1">Twoje produkty</div>
      </div>
      <button
        type="button"
        data-drawer-close
        class="w-10 h-10 inline-flex items-center justify-center hover:bg-paper-warm rounded-full transition"
        aria-label="Zamknij"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path d="M10 8.6L15.3 3.3l1.4 1.4-5.3 5.3 5.3 5.3-1.4 1.4-5.3-5.3-5.3 5.3-1.4-1.4 5.3-5.3-5.3-5.3 1.4-1.4z"/></svg>
      </button>
    </div>

    <div data-drawer-items class="flex-1 overflow-y-auto px-6 py-4 space-y-3">
      <!-- items injected via JS using DOM methods -->
    </div>

    <div data-drawer-empty class="hidden px-6 py-8 text-center text-muted">
      Twój koszyk jest pusty.<br/>
      <a href="/katalog" class="text-accent underline underline-offset-4 mt-3 inline-block">Przejdź do katalogu →</a>
    </div>

    <div class="border-t border-line p-6 space-y-3">
      <a
        href="/zamowienie"
        data-drawer-cta
        class="block w-full text-center rounded-full bg-ink text-paper px-6 py-3 font-semibold hover:bg-accent transition"
      >
        Przejdź do formularza
      </a>
      <p class="text-xs text-muted text-center leading-relaxed">
        Nie kupujesz online — wysyłasz zapytanie. Skontaktujemy się mailowo, ustalimy dostępność i sposób odbioru.
      </p>
    </div>
  </aside>
</div>

<script>
  import { getCart, updateQty, removeItem, type InquiryItem } from '../scripts/inquiry-cart';
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');
  const itemsEl = drawer?.querySelector<HTMLElement>('[data-drawer-items]');
  const emptyEl = drawer?.querySelector<HTMLElement>('[data-drawer-empty]');
  const ctaEl = drawer?.querySelector<HTMLElement>('[data-drawer-cta]');
  const closeBtn = drawer?.querySelector<HTMLElement>('[data-drawer-close]');
  const backdrop = drawer?.querySelector<HTMLElement>('[data-drawer-backdrop]');

  const open = () => {
    if (!drawer) return;
    render();
    drawer.classList.remove('hidden');
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    if (!drawer) return;
    drawer.classList.add('hidden');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  function el(tag: string, opts: { class?: string; text?: string; attrs?: Record<string, string> } = {}) {
    const n = document.createElement(tag);
    if (opts.class) n.className = opts.class;
    if (opts.text) n.textContent = opts.text;
    if (opts.attrs) for (const [k, v] of Object.entries(opts.attrs)) n.setAttribute(k, v);
    return n;
  }

  function buildRow(it: InquiryItem): HTMLElement {
    const row = el('div', { class: 'flex gap-3 items-center' });

    const img = el('img', {
      class: 'w-16 h-20 object-cover rounded bg-line shrink-0',
      attrs: { src: it.image, alt: '', loading: 'lazy' },
    });
    row.appendChild(img);

    const body = el('div', { class: 'flex-1 min-w-0' });
    body.appendChild(el('div', { class: 'font-semibold truncate', text: it.name }));
    body.appendChild(el('div', { class: 'text-xs text-muted truncate', text: `${it.flavor} · ${it.volume}` }));

    const qtyWrap = el('div', { class: 'mt-2 inline-flex items-center border border-line rounded-full overflow-hidden text-sm' });
    const dec = el('button', { class: 'w-7 h-7 hover:bg-paper-warm', text: '−', attrs: { type: 'button', 'aria-label': 'Mniej' } }) as HTMLButtonElement;
    const qtySpan = el('span', { class: 'w-8 text-center', text: String(it.qty) });
    const inc = el('button', { class: 'w-7 h-7 hover:bg-paper-warm', text: '+', attrs: { type: 'button', 'aria-label': 'Więcej' } }) as HTMLButtonElement;
    dec.addEventListener('click', () => updateQty(it.slug, it.qty - 1));
    inc.addEventListener('click', () => updateQty(it.slug, it.qty + 1));
    qtyWrap.append(dec, qtySpan, inc);
    body.appendChild(qtyWrap);
    row.appendChild(body);

    const rm = el('button', { class: 'text-xs text-muted hover:text-accent', text: 'usuń', attrs: { type: 'button', 'aria-label': 'Usuń' } }) as HTMLButtonElement;
    rm.addEventListener('click', () => removeItem(it.slug));
    row.appendChild(rm);

    return row;
  }

  const render = () => {
    if (!itemsEl || !emptyEl || !ctaEl) return;
    const items = getCart();
    itemsEl.replaceChildren();
    if (items.length === 0) {
      itemsEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      ctaEl.classList.add('opacity-50', 'pointer-events-none');
      return;
    }
    itemsEl.classList.remove('hidden');
    emptyEl.classList.add('hidden');
    ctaEl.classList.remove('opacity-50', 'pointer-events-none');
    items.forEach((it) => itemsEl.appendChild(buildRow(it)));
  };

  document.addEventListener('drawer:open', open);
  closeBtn?.addEventListener('click', close);
  backdrop?.addEventListener('click', close);
  window.addEventListener('cart:change', () => {
    if (drawer && !drawer.classList.contains('hidden')) render();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer && !drawer.classList.contains('hidden')) close();
  });
</script>
