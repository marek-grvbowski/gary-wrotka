---
type Props = {
  images: string[];
  alt?: string;
};
const { images, alt = '' } = Astro.props;
---
<div class="masonry">
  {images.map((src, i) => (
    <img
      src={src}
      alt={alt || `Zdjęcie ${i + 1}`}
      loading={i < 3 ? 'eager' : 'lazy'}
      decoding="async"
      class="fade-img rounded-lg w-full h-auto transition-transform duration-[900ms] ease-out hover:scale-[1.02]"
    />
  ))}
</div>
