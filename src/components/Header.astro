---
import { getEntry } from 'astro:content';

type Props = {
  initialMode?: 'dark' | 'light';
};

const { initialMode = 'light' } = Astro.props;
const { pathname } = Astro.url;

const site = await getEntry('site', 'site');
const brand = site?.data.brandName ?? 'Gary Wrotka';

const links = [
  { href: '/katalog', label: 'Katalog' },
  { href: '/o-nas', label: 'Manifest' },
  { href: '/blog', label: 'Dziennik' },
  { href: '/b2b', label: 'B2B' },
  { href: '/kontakt', label: 'Kontakt' },
];
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---
<header class="nav" data-initial-mode={initialMode}>
  <div class="container nav-inner">
    <a href="/" class="nav-brand" aria-label={brand}>
      <img src="/images/brand/logo-mark.svg" alt="" width="28" height="25"/>
      <span>{brand}</span>
    </a>
    <nav class="nav-links">
      {links.map((l) => (
        <a
          href={l.href}
          class="nav-link"
          {...(isActive(l.href) ? { 'aria-current': 'page' } : {})}
        >
          {l.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <button
        type="button"
        class="theme-toggle"
        data-theme-toggle
        aria-label="Przełącz motyw"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <a
        href="/zamowienie"
        class="nav-cart"
        data-open-drawer
        aria-label="Otwórz koszyk"
      >
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 4h2l2 10h9l2-7H6"/><circle cx="8" cy="17" r="1.2"/><circle cx="15" cy="17" r="1.2"/></svg>
        <span>Koszyk</span>
        <span class="cart-dot" data-cart-count data-empty="1">0</span>
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('header.nav');
  if (header) {
    const HEADER_H = 64;

    const onScroll = () => {
      header.classList.toggle('scrolled', window.scrollY > 40);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Adaptive nav theme — obserwuj sekcje pod headerem
    const themedSections = document.querySelectorAll<HTMLElement>('[data-nav-theme]');
    let visibleSections: HTMLElement[] = [];

    const updateNav = () => {
      // znajdź najbardziej z dołu widoczną sekcję pod headerem (jeśli kilka, ta która "kończy się najwyżej")
      const topSection = visibleSections.reduce<HTMLElement | null>((acc, el) => {
        const r = el.getBoundingClientRect();
        if (r.top <= HEADER_H + 2 && r.bottom > HEADER_H) {
          if (!acc || el.getBoundingClientRect().top > acc.getBoundingClientRect().top) return el;
        }
        return acc;
      }, null);
      const theme = topSection?.dataset.navTheme || 'light-bg';
      header.classList.toggle('over-dark', theme === 'dark');
    };

    if (themedSections.length > 0 && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const el = entry.target as HTMLElement;
            if (entry.isIntersecting) {
              if (!visibleSections.includes(el)) visibleSections.push(el);
            } else {
              visibleSections = visibleSections.filter((s) => s !== el);
            }
          });
          updateNav();
        },
        { rootMargin: `-${HEADER_H}px 0px 0px 0px`, threshold: 0 }
      );
      themedSections.forEach((s) => io.observe(s));

      window.addEventListener('scroll', updateNav, { passive: true });
      updateNav();
    }

    // open drawer when cart link clicked (if on a page that has drawer)
    header.querySelector('[data-open-drawer]')?.addEventListener('click', (e) => {
      const drawer = document.querySelector('[data-drawer]');
      if (drawer) {
        e.preventDefault();
        document.dispatchEvent(new CustomEvent('drawer:open'));
      }
    });
  }
</script>
