---
type Props = {
  images: string[];
  tagline: string;
  brand: string;
};
const { images, tagline, brand } = Astro.props;
const slideDuration = 5500;
---
<section class="hero snap-strong relative min-h-screen md:min-h-[100vh] flex items-end bg-ink text-paper overflow-hidden" data-slide-duration={slideDuration}>
  <div class="hero-stage absolute inset-0">
    {images.map((src, i) => (
      <div
        class={`hero-slide absolute inset-0 ${i === 0 ? 'active' : ''}`}
        data-slide-index={i}
      >
        <img
          src={src}
          alt=""
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          class="hero-img absolute inset-0 w-full h-full object-cover"
        />
      </div>
    ))}
    <div class="absolute inset-0 bg-gradient-to-b from-ink/30 via-ink/15 to-ink/85 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-ink/30 via-transparent to-ink/0 pointer-events-none"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[var(--container-content)] px-6 py-32 md:py-40 w-full">
    <div class="max-w-3xl">
      <div class="eyebrow text-paper/70 hero-fade-in" style="--d:0ms">Nowy Sącz · od 2024</div>
      <h1 class="font-display font-bold text-4xl md:text-6xl lg:text-7xl tracking-tight mt-4 leading-[1.05] hero-fade-in" style="--d:120ms">
        {brand}
      </h1>
      <p class="mt-5 text-lg md:text-2xl text-paper/85 max-w-2xl hero-fade-in" style="--d:260ms">
        {tagline}
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4 hero-fade-in" style="--d:420ms">
        <a
          href="/katalog"
          class="magnetic inline-flex items-center gap-2 rounded-full bg-paper text-ink px-7 py-3.5 text-sm font-semibold hover:bg-accent hover:text-paper transition-colors"
        >
          <span>Zobacz katalog</span>
          <span class="arrow inline-block transition-transform" aria-hidden="true">→</span>
        </a>
        <a
          href="/o-nas"
          class="inline-flex items-center gap-2 rounded-full border border-paper/30 px-6 py-3 text-sm font-medium hover:border-paper hover:bg-paper/10 transition"
        >
          Poznaj historię
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex items-center gap-3 hero-fade-in" style="--d:600ms" data-hero-controls>
    <button type="button" data-hero-prev aria-label="Poprzedni slajd" class="w-9 h-9 rounded-full border border-paper/30 hover:border-paper hover:bg-paper/10 transition flex items-center justify-center">‹</button>
    <div class="flex gap-2" data-hero-dots>
      {images.map((_, i) => (
        <button
          type="button"
          aria-label={`Slajd ${i + 1}`}
          data-dot-index={i}
          class={`hero-dot relative h-1 rounded-full transition-all duration-500 ${i === 0 ? 'bg-paper/30 w-10' : 'bg-paper/30 w-6'}`}
        >
          <span class={`hero-dot-fill absolute inset-y-0 left-0 bg-paper rounded-full ${i === 0 ? 'w-full' : 'w-0'}`} data-dot-fill></span>
        </button>
      ))}
    </div>
    <button type="button" data-hero-next aria-label="Następny slajd" class="w-9 h-9 rounded-full border border-paper/30 hover:border-paper hover:bg-paper/10 transition flex items-center justify-center">›</button>
  </div>

  <div class="absolute bottom-2 left-6 z-10 hero-fade-in" style="--d:700ms">
    <div class="flex flex-col items-center gap-1 text-paper/50 text-[10px] uppercase tracking-[0.3em]">
      <span>Scroll</span>
      <span class="scroll-pulse w-px h-8 bg-paper/40"></span>
    </div>
  </div>

  <div data-hero-sentinel aria-hidden="true" class="absolute bottom-0 h-px w-full"></div>
</section>

<script>
  const hero = document.querySelector<HTMLElement>('.hero');
  if (hero) {
    const stage = hero.querySelector<HTMLElement>('.hero-stage');
    const slides = Array.from(hero.querySelectorAll<HTMLElement>('.hero-slide'));
    const dots = Array.from(hero.querySelectorAll<HTMLButtonElement>('[data-dot-index]'));
    const dotFills = Array.from(hero.querySelectorAll<HTMLElement>('[data-dot-fill]'));
    const prevBtn = hero.querySelector<HTMLButtonElement>('[data-hero-prev]');
    const nextBtn = hero.querySelector<HTMLButtonElement>('[data-hero-next]');
    const duration = Number(hero.dataset.slideDuration || 5500);
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let idx = 0;
    let timer: number | undefined;

    const show = (n: number) => {
      const total = slides.length;
      const target = ((n % total) + total) % total;
      slides.forEach((s, i) => s.classList.toggle('active', i === target));
      dots.forEach((d, i) => {
        d.classList.toggle('w-10', i === target);
        d.classList.toggle('w-6', i !== target);
      });
      dotFills.forEach((f, i) => {
        f.style.transition = 'none';
        f.style.width = '0%';
        if (i === target && !reduceMotion) {
          // restart progress fill animation
          // eslint-disable-next-line @typescript-eslint/no-unused-expressions
          f.offsetHeight;
          f.style.transition = `width ${duration}ms linear`;
          f.style.width = '100%';
        } else if (i === target && reduceMotion) {
          f.style.width = '100%';
        }
      });
      idx = target;
    };

    const advance = () => show(idx + 1);
    const start = () => {
      if (reduceMotion || slides.length < 2) return;
      window.clearInterval(timer);
      timer = window.setInterval(advance, duration);
    };
    const reset = () => {
      start();
    };

    prevBtn?.addEventListener('click', () => { show(idx - 1); reset(); });
    nextBtn?.addEventListener('click', () => { show(idx + 1); reset(); });
    dots.forEach((d) => d.addEventListener('click', () => { show(Number(d.dataset.dotIndex)); reset(); }));

    // Mouse parallax — subtle drift of the active image
    if (!reduceMotion && stage) {
      let raf = 0;
      let tx = 0, ty = 0;
      hero.addEventListener('mousemove', (e) => {
        const r = hero.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        tx = x * 14;
        ty = y * 10;
        if (!raf) raf = requestAnimationFrame(apply);
      });
      hero.addEventListener('mouseleave', () => { tx = 0; ty = 0; if (!raf) raf = requestAnimationFrame(apply); });
      const apply = () => {
        stage.style.transform = `translate3d(${tx}px, ${ty}px, 0)`;
        raf = 0;
      };
    }

    // pause on tab hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) window.clearInterval(timer);
      else start();
    });

    // init first fill + autoplay
    show(0);
    start();
  }
</script>
