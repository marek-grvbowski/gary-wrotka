---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProductCard from '../components/ProductCard.astro';
import BlogCard from '../components/BlogCard.astro';

const site = await getEntry('site', 'site');
const data = site?.data;

const products = (await getCollection('products', (p) => p.data.featured && p.data.available))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const blogPosts = (await getCollection('blog', (p) => !p.data.draft))
  .sort((a, b) => +b.data.pubDate - +a.data.pubDate)
  .slice(0, 2);

const process = [
  { title: 'Surowce', body: 'Lokalne owoce, polskie zioła, herbaty od sprawdzonych dostawców.' },
  { title: 'SCOBY', body: 'Żywe kultury bakterii i drożdży hodowane u nas od początku.' },
  { title: 'Fermentacja', body: '7–14 dni w temperaturze pokojowej, w bursztynowym szkle.' },
  { title: 'Karbonizacja', body: 'Druga fermentacja w butelce — naturalny gaz, bez dosypywania.' },
  { title: 'Magazyn', body: 'Chłodno, ciemno, krótko. Trafia do Ciebie świeże.' },
];
---
<Layout
  title="Gary Wrotka — rzemieślnicze fermenty z Wrocławia"
  description={data?.tagline}
  headerMode="dark"
>
  <HeroCarousel
    images={data?.heroImages ?? []}
    brand={data?.brandName ?? 'Gary Wrotka'}
    tagline={data?.tagline ?? ''}
  />

  <section class="bg-paper py-24 md:py-32">
    <div class="mx-auto max-w-[var(--container-content)] px-6 grid md:grid-cols-12 gap-12 items-start reveal">
      <div class="md:col-span-4">
        <SectionHeading
          eyebrow="Manifest"
          title="Fermentacja jako forma cierpliwości"
        />
      </div>
      <div class="md:col-span-7 md:col-start-6 space-y-5 text-lg leading-relaxed text-ink-soft">
        <p>
          Robimy to, czego brakowało nam w sklepach: napoje, które naprawdę żyją.
          Nie pasteryzujemy, nie cukrzymy do smaku, nie dosypujemy gazu.
          Fermentacja dzieje się powoli — i tak ma być.
        </p>
        <p>
          Wrocław, lokalne owoce, starannie wybrane herbaty, ręczne butelkowanie.
          Każda partia jest trochę inna — bo ma być.
        </p>
        <p>
          Marka powstała z pasji do dokumentowania rzemiosła. Stąd jej druga noga —
          fotografia, którą mówimy o procesie. Zobaczysz ją w katalogu, na blogu, w opakowaniach.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-paper py-20 border-t border-line">
    <div class="mx-auto max-w-[var(--container-content)] px-6">
      <div class="flex items-end justify-between gap-6 flex-wrap mb-12 reveal">
        <SectionHeading
          eyebrow="Smaki"
          title="Wybrane z katalogu"
          intro="Trzy fermenty, które polecamy na start — od delikatnego jaśminu do mocnego, kawowego Fermento Nero."
        />
        <a href="/katalog" class="text-sm font-medium text-accent hover:text-accent-deep underline underline-offset-4">
          Cały katalog →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
        {products.map((p) => (
          <ProductCard
            slug={p.id}
            name={p.data.name}
            flavor={p.data.flavor}
            category={p.data.category}
            volume={p.data.volume}
            image={p.data.images[0]}
            available={p.data.available}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="bg-paper-warm py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-6">
      <div class="reveal">
      <SectionHeading
        eyebrow="Proces"
        title="Pięć kroków do żywego napoju"
        intro="Nic nie jest przypadkowe. Każdy krok dyktuje smak końcowy."
      />
      </div>
      <ol class="mt-12 grid md:grid-cols-5 gap-6 reveal-stagger">
        {process.map((step, i) => (
          <li class="bg-paper rounded-xl p-6 border border-line">
            <div class="font-display font-bold text-3xl text-accent">{String(i + 1).padStart(2, '0')}</div>
            <div class="mt-3 font-display font-semibold text-lg">{step.title}</div>
            <p class="mt-2 text-sm text-muted leading-relaxed">{step.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="bg-paper py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-6">
      <div class="flex items-end justify-between gap-6 flex-wrap mb-12 reveal">
        <SectionHeading
          eyebrow="Z bloga"
          title="O fermentacji i nie tylko"
        />
        <a href="/blog" class="text-sm font-medium text-accent hover:text-accent-deep underline underline-offset-4">
          Wszystkie wpisy →
        </a>
      </div>
      <div class="grid md:grid-cols-2 gap-12 reveal-stagger">
        {blogPosts.map((p) => (
          <BlogCard
            slug={p.id}
            title={p.data.title}
            description={p.data.description}
            cover={p.data.cover}
            pubDate={p.data.pubDate}
            tags={p.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="bg-ink text-paper py-16">
    <div class="mx-auto max-w-[var(--container-content)] px-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 reveal">
      <div>
        <div class="eyebrow text-paper/50">Hurt / HoReCa</div>
        <h2 class="font-display font-bold text-3xl md:text-4xl mt-3 max-w-2xl">
          Prowadzisz lokal, sklep, delikatesy?
        </h2>
        <p class="mt-3 text-paper/75 max-w-2xl">
          Mamy osobny landing dla partnerów hurtowych. Indywidualne wyceny, regularne dostawy, wsparcie marketingowe.
        </p>
      </div>
      <a
        href="/b2b"
        class="magnetic inline-flex items-center gap-2 rounded-full bg-paper text-ink px-7 py-3.5 font-semibold hover:bg-accent hover:text-paper transition-colors shrink-0"
      >
        <span>Zobacz ofertę B2B</span>
        <span class="arrow inline-block transition-transform" aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>
