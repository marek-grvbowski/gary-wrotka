---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const homeEntry = await getEntry('home', 'home');
const globalEntry = await getEntry('global', 'global');
const data = { ...(homeEntry?.data ?? {}), ...(globalEntry?.data ?? {}) };

const allProducts = (await getCollection('products', (p) => p.data.available))
  .sort((a, b) => a.data.order - b.data.order);

const blogPosts = (await getCollection('blog', (p) => !p.data.draft))
  .sort((a, b) => +b.data.pubDate - +a.data.pubDate)
  .slice(0, 2);

const heroImages = data?.heroImages ?? [];

const heroTitle = data?.homeHero?.title ?? 'Rzemieślnicze fermenty z Nowego Sącza.';
const heroSub = data?.homeHero?.subtitle ?? '';
const heroEyebrow = data?.homeHero?.eyebrow ?? '';
const heroPrimary = data?.homeHero?.primaryCta ?? { label: 'Zobacz katalog', href: '/katalog' };
const heroSecondary = data?.homeHero?.secondaryCta ?? { label: 'Manifest', href: '#manifest' };

const sections = data?.homeSections ?? { manifest: true, featured: true, process: true, blog: true, b2b: true };

const manifest = data?.manifest;
const manifestParagraphs = (manifest?.body ?? '').split('\n\n').filter(Boolean);

const featured = data?.featured;
const processSection = data?.processSection;
const blogSection = data?.blogSection;
const b2b = data?.b2b;

const filters = [
  { id: 'all', label: 'Wszystkie' },
  { id: 'kombucha', label: 'Kombucha' },
  { id: 'sos', label: 'Sosy' },
  { id: 'ocet', label: 'Octy' },
];
---
<Layout
  title="Gary Wrotka — rzemieślnicze fermenty z Nowego Sącza"
  description={data?.tagline}
  headerMode="dark"
  bodyClass="home-page"
>
  <!-- HOME HERO ─────────────────────────────────────────── -->
  <section class="home-hero" data-home-hero data-nav-theme="dark">
    <div class="hh-stage">
      {heroImages.map((src, i) => (
        <div class={`hh-slide ${i === 0 ? 'active' : ''}`} data-hero-slide={i}>
          <img src={src} alt="" class="hh-img fade-img" loading={i === 0 ? 'eager' : 'lazy'} decoding="async"/>
        </div>
      ))}
      <div class="hh-overlay"></div>
    </div>

    <div class="container hh-content">
      <div class="hh-text">
        <div class="hh-eyebrow page-in" style="animation-delay: 0.1s">{heroEyebrow}</div>
        <h1 class="hh-title display" data-hero-title>
          {heroTitle.split(' ').map((word, i) => (
            <Fragment><span class="split-word" style={`--d: ${300 + i * 80}ms`}><span>{word}</span></span>{' '}</Fragment>
          ))}
        </h1>
        <p class="hh-sub page-in" style="animation-delay: 0.9s">{heroSub}</p>
        <div class="hh-cta page-in" style="animation-delay: 1.1s">
          <a href={heroPrimary.href} class="magnetic btn-primary">
            <span>{heroPrimary.label}</span>
            <span class="arrow">→</span>
          </a>
          <a href={heroSecondary.href} class="btn-ghost btn-ghost-light">{heroSecondary.label}</a>
        </div>
      </div>

      <div class="hh-meta">
        <button class="hh-arrow" data-hero-prev aria-label="Poprzednie">←</button>
        <div class="hh-counter">
          <span class="cur" data-hero-cur>01</span>
          <span class="sep"></span>
          <span class="tot">{String(heroImages.length).padStart(2, '0')}</span>
        </div>
        <button class="hh-arrow" data-hero-next aria-label="Następne">→</button>
      </div>

      <div class="hh-scroll">
        <span>Scroll</span>
        <div class="hh-scroll-line"><div></div></div>
      </div>
    </div>
  </section>

  {sections.manifest && (
  <!-- MANIFEST ──────────────────────────────────────────── -->
  <section class="container manifest-section" id="manifest">
    <div class="manifest-grid">
      <div class="manifest-text reveal-left">
        <div class="eyebrow" style="margin-bottom: 24px">{manifest?.eyebrow}</div>
        <h2 class="manifest-h display">{manifest?.title}</h2>
        {manifestParagraphs.map((p) => <p class="manifest-p">{p}</p>)}
        {manifest?.ctaLabel && (
          <a href={manifest.ctaHref} class="btn-ghost" style="margin-top: 24px">
            {manifest.ctaLabel} <span>→</span>
          </a>
        )}
      </div>
      <div class="manifest-media reveal-clip">
        <img src={manifest?.image} alt="" loading="lazy" class="fade-img"/>
        {manifest?.caption && <div class="caption">{manifest.caption}</div>}
      </div>
    </div>
  </section>
  )}

  {sections.featured && (
  <!-- FEATURED ──────────────────────────────────────────── -->
  <section class="container featured-section">
    <div class="featured-head reveal">
      <div>
        <div class="eyebrow" style="margin-bottom: 18px">{featured?.eyebrow}</div>
        <h2 class="profile-h" style="margin: 0">{featured?.title}</h2>
      </div>
      <div class="filter-row" data-filter-row>
        {filters.map((f) => (
          <button class={`filter-pill ${f.id === 'all' ? 'active' : ''}`} data-filter={f.id} type="button">{f.label}</button>
        ))}
      </div>
    </div>
    <div class="featured-grid reveal-stagger" data-product-grid>
      {allProducts.map((p) => (
        <a href={`/katalog/${p.id}`} class="prod-card prod-card-home" data-category={p.data.category}>
          <div class="prod-media">
            <img src={p.data.images[0]} alt={p.data.name} loading="lazy" class="fade-img"/>
            {p.data.tag && <div class="prod-tag">{p.data.tag}</div>}
          </div>
          <div class="prod-body">
            <div class="prod-cat">{p.data.categoryLabel ?? p.data.category}</div>
            <h3 class="prod-name">{p.data.name}</h3>
            <div class="prod-flavor">{p.data.flavor}</div>
          </div>
        </a>
      ))}
    </div>
    <div class="featured-foot reveal">
      <a href="/katalog" class="magnetic btn-primary">
        <span>Cały katalog ({allProducts.length} produktów)</span>
        <span class="arrow">→</span>
      </a>
    </div>
  </section>
  )}

  {sections.process && (
  <!-- PROCESS TEASER ────────────────────────────────────── -->
  <section class="process-teaser">
    <div class="container">
      <div class="pt-head reveal-left">
        <div class="eyebrow" style="margin-bottom: 18px">{processSection?.eyebrow}</div>
        <h2 class="profile-h" style="margin: 0">{processSection?.title}</h2>
      </div>
      <div class="pt-grid reveal-stagger">
        {processSection?.steps.map((s) => (
          <div class="pt-step">
            <div class="pt-n mono">{s.n}</div>
            <h3 class="pt-l display">{s.label}</h3>
            <p class="pt-d">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  )}

  {sections.blog && (
  <!-- BLOG TEASER ───────────────────────────────────────── -->
  <section class="container blog-section">
    <div class="blog-head reveal">
      <div>
        <div class="eyebrow" style="margin-bottom: 18px">{blogSection?.eyebrow}</div>
        <h2 class="profile-h" style="margin: 0">{blogSection?.title}</h2>
      </div>
      <a href="/blog" class="btn-ghost">Cały dziennik <span>→</span></a>
    </div>
    <div class="blog-grid reveal-stagger">
      {blogPosts.map((post) => {
        const formatted = new Intl.DateTimeFormat('pl-PL', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(post.data.pubDate);
        return (
          <a href={`/blog/${post.id}`} class="blog-card">
            {post.data.cover && (
              <div class="blog-media">
                <img src={post.data.cover} alt={post.data.title} loading="lazy" class="fade-img"/>
              </div>
            )}
            <div class="blog-body">
              <div class="blog-meta mono">
                {post.data.tags[0] && <span>{post.data.tags[0]}</span>}
                {post.data.tags[0] && <span class="bsep">·</span>}
                <span>{formatted}</span>
              </div>
              <h3 class="blog-title">{post.data.title}</h3>
              <p class="blog-excerpt">{post.data.description}</p>
              <span class="prod-cta">Czytaj <span class="a">→</span></span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
  )}

  {sections.b2b && (
  <!-- B2B CTA ───────────────────────────────────────────── -->
  <section class="b2b-section" data-nav-theme="dark">
    <div class="container b2b-inner reveal">
      <div class="eyebrow b2b-eyebrow">{b2b?.eyebrow}</div>
      <h2 class="b2b-h display">
        {b2b?.title}<br/>
        <span class="b2b-accent">{b2b?.accent}</span>
      </h2>
      {b2b?.body && <p class="b2b-p">{b2b.body}</p>}
      <div class="b2b-cta">
        <a href={b2b?.buttonHref ?? '/b2b'} class="magnetic btn-primary btn-primary-light">
          <span>{b2b?.buttonLabel}</span>
          <span class="arrow">→</span>
        </a>
        {b2b?.mail && <a href={`mailto:${b2b.mail}`} class="b2b-mail mono">{b2b.mail}</a>}
      </div>
    </div>
  </section>
  )}

</Layout>

<script>
  // Hero carousel
  const total = document.querySelectorAll<HTMLElement>('[data-hero-slide]').length;
  let active = 0;
  let paused = false;
  let timer: number | undefined;

  const show = (n: number) => {
    const target = ((n % total) + total) % total;
    document.querySelectorAll<HTMLElement>('[data-hero-slide]').forEach((el, i) => {
      el.classList.toggle('active', i === target);
    });
    const cur = document.querySelector<HTMLElement>('[data-hero-cur]');
    if (cur) cur.textContent = String(target + 1).padStart(2, '0');
    active = target;
  };
  const advance = () => show(active + 1);
  const start = () => {
    if (paused) return;
    window.clearInterval(timer);
    timer = window.setInterval(advance, 6500);
  };

  document.querySelector('[data-hero-prev]')?.addEventListener('click', () => { paused = true; window.clearInterval(timer); show(active - 1); });
  document.querySelector('[data-hero-next]')?.addEventListener('click', () => { paused = true; window.clearInterval(timer); show(active + 1); });

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) window.clearInterval(timer);
    else if (!paused) start();
  });

  if (total > 1) start();

  // Hero title split-word reveal
  requestAnimationFrame(() => {
    document.querySelectorAll<HTMLElement>('[data-hero-title] .split-word').forEach((s) => {
      s.classList.add('in');
    });
  });

  // Featured filter
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const items = document.querySelectorAll<HTMLElement>('[data-product-grid] [data-category]');
  const apply = (cat: string) => {
    buttons.forEach((b) => b.classList.toggle('active', b.dataset.filter === cat));
    items.forEach((it) => {
      it.style.display = cat === 'all' || it.dataset.category === cat ? '' : 'none';
    });
  };
  buttons.forEach((b) => b.addEventListener('click', () => apply(b.dataset.filter!)));
</script>
