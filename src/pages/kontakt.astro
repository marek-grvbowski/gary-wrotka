---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const site = await getEntry('global', 'global');
const data = site?.data;
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const isOk = Astro.url.searchParams.get('ok') === '1';
---
<Layout
  title="Kontakt — Gary Wrotka"
  description="Napisz do nas — pytanie o produkt, współpracę, fermentację."
>
  <section class="container">
    <div class="breadcrumb">
      <a href="/">Start</a>
      <span class="sep">/</span>
      <span style="color: var(--color-ink)">Kontakt</span>
    </div>

    <header class="reveal" style="padding-bottom: clamp(56px, 7vw, 96px); max-width: 880px">
      <div class="eyebrow" style="margin-bottom: 18px">Kontakt</div>
      <h1 class="display" style="font-size: clamp(48px, 6vw, 88px); margin: 0 0 24px; line-height: 1">
        Napisz, zadzwoń,<br/>wpadnij.
      </h1>
      <p style="font-size: 18px; line-height: 1.7; color: var(--color-ink-soft); margin: 0; max-width: 620px">
        Najłatwiej mailem albo formularzem. Telefon też działa, ale jak na rzemieślników przystało — nie zawsze go słyszymy.
      </p>
    </header>
  </section>

  <section class="container" style="padding-bottom: var(--gap-section)">
    <div class="story" style="padding-top: 0; padding-bottom: 0; align-items: start">
      <div class="reveal-left" style="display: flex; flex-direction: column; gap: 36px">
        {data?.contactEmail && (
          <div>
            <div class="eyebrow" style="margin-bottom: 10px">Mail</div>
            <a href={`mailto:${data.contactEmail}`} class="display" style="font-size: clamp(22px, 2.4vw, 32px); text-decoration: underline; text-underline-offset: 6px">
              {data.contactEmail}
            </a>
            {data?.orderEmail && data.orderEmail !== data.contactEmail && (
              <div style="margin-top: 8px"><a href={`mailto:${data.orderEmail}`} style="color: var(--color-muted); font-size: 14px">zamówienia: {data.orderEmail}</a></div>
            )}
          </div>
        )}

        {data?.phone && (
          <div>
            <div class="eyebrow" style="margin-bottom: 10px">Telefon</div>
            <a href={`tel:${data.phone.replace(/\s/g, '')}`} class="display" style="font-size: clamp(20px, 2.2vw, 28px)">
              {data.phone}
            </a>
          </div>
        )}

        {data?.address && (
          <div>
            <div class="eyebrow" style="margin-bottom: 10px">Adres</div>
            <p style="font-size: 16px; line-height: 1.7; color: var(--color-ink-soft); margin: 0">{data.address}</p>
          </div>
        )}

        <div>
          <div class="eyebrow" style="margin-bottom: 10px">Social</div>
          <div style="display: flex; flex-wrap: wrap; gap: 12px">
            {data?.socials?.instagram && (
              <a href={data.socials.instagram} class="btn-ghost" style="padding: 8px 16px; font-size: 13px">Instagram</a>
            )}
            {data?.socials?.facebook && (
              <a href={data.socials.facebook} class="btn-ghost" style="padding: 8px 16px; font-size: 13px">Facebook</a>
            )}
          </div>
        </div>
      </div>

      <div class="reveal-right">
        {isOk ? (
          <div style="background: var(--color-paper-warm); border: 1px solid var(--color-line); border-radius: 6px; padding: 48px 32px; text-align: center">
            <div style="font-size: 40px; line-height: 1; color: var(--color-accent)">✓</div>
            <h2 class="display" style="margin: 16px 0 8px; font-size: 24px">Wiadomość wysłana</h2>
            <p style="color: var(--color-muted); margin: 0">Odezwiemy się w ciągu 24h roboczych.</p>
          </div>
        ) : (
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            style="display: flex; flex-direction: column; gap: 16px"
          >
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="subject" value="[Gary Wrotka] Wiadomość z formularza kontaktowego" />
            <input type="hidden" name="from_name" value="Gary Wrotka — kontakt" />
            <input type="hidden" name="tag" value="kontakt" />
            <input type="text" name="botcheck" tabindex="-1" autocomplete="off" style="display: none" />

            <label style="display: flex; flex-direction: column; gap: 6px">
              <span class="eyebrow">Imię *</span>
              <input type="text" name="name" required style="padding: 14px 16px; background: var(--color-paper-warm); border: 1px solid var(--color-line); border-radius: 4px; font: inherit"/>
            </label>
            <label style="display: flex; flex-direction: column; gap: 6px">
              <span class="eyebrow">E-mail *</span>
              <input type="email" name="email" required style="padding: 14px 16px; background: var(--color-paper-warm); border: 1px solid var(--color-line); border-radius: 4px; font: inherit"/>
            </label>
            <label style="display: flex; flex-direction: column; gap: 6px">
              <span class="eyebrow">Wiadomość *</span>
              <textarea name="message" rows="6" required style="padding: 14px 16px; background: var(--color-paper-warm); border: 1px solid var(--color-line); border-radius: 4px; font: inherit; resize: vertical"></textarea>
            </label>
            <input type="hidden" name="redirect" value={new URL('/kontakt?ok=1', Astro.url).toString()} />

            <button type="submit" class="magnetic btn-primary" style="margin-top: 12px; align-self: start">
              <span>Wyślij wiadomość</span>
              <span class="arrow">→</span>
            </button>
          </form>
        )}
      </div>
    </div>
  </section>
</Layout>
