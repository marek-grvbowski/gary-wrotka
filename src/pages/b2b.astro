---
import Layout from '../layouts/Layout.astro';
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';

const usp = [
  { n: '01', title: 'Rzemiosło, nie linia produkcyjna', body: 'Każda partia robiona ręcznie, w małych nakładach. Produkty żyją — w sklepie wyróżniają się autentycznością.' },
  { n: '02', title: 'Indywidualne wyceny i terminy', body: 'Bez sztywnego cennika. Po rozmowie ustalamy regularne dostawy lub jednorazowe partie pod event.' },
  { n: '03', title: 'Wsparcie wizerunkowe', body: 'Materiały marketingowe, foto, tekst o marce, ekspozycja na social mediach.' },
];

const partners = ['Restauracja 1', 'Cafe 2', 'Delikatesy 3', 'Bistro 4', 'Hotel 5', 'Wino & Spiżarnia 6'];
---
<Layout
  title="B2B — Gary Wrotka dla lokali i sklepów"
  description="Hurtowa oferta naszych fermentów dla restauracji, sklepów, delikatesów i hoteli."
  headerMode="dark"
>
  <!-- Hero B2B dark -->
  <section class="home-hero" data-nav-theme="dark" style="min-height: 80vh; height: auto; padding-bottom: 96px">
    <div class="hh-stage">
      <div class="hh-slide active">
        <img src="/images/photos/_DSC4615.jpg" alt="" class="hh-img fade-img"/>
      </div>
      <div class="hh-overlay" style="background: linear-gradient(to top, rgba(0,0,0,0.7), rgba(0,0,0,0.3) 60%, rgba(0,0,0,0.4))"></div>
    </div>

    <div class="container hh-content" style="padding-top: 140px">
      <div class="hh-text" style="max-width: 880px">
        <div class="hh-eyebrow page-in" style="animation-delay: 0.1s">Hurt · HoReCa · Sklepy specjalistyczne</div>
        <h1 class="hh-title display page-in" style="animation-delay: 0.3s">
          Gary Wrotka<br/>dla profesjonalistów.
        </h1>
        <p class="hh-sub page-in" style="animation-delay: 0.9s; max-width: 620px">
          Robimy fermenty, których nie znajdziesz w hurtowniach. Wyselekcjonowani partnerzy w Polsce dostają od nas regularne dostawy i wsparcie sprzedażowe.
        </p>
        <div class="hh-cta page-in" style="animation-delay: 1.1s">
          <a href="#kontakt-b2b" class="magnetic btn-primary">
            <span>Wyślij zapytanie hurtowe</span>
            <span class="arrow">→</span>
          </a>
          <a href="#cennik" class="btn-ghost btn-ghost-light">Pobierz cennik</a>
        </div>
      </div>
    </div>
  </section>

  <!-- USP -->
  <section class="container" style="padding-top: var(--gap-section); padding-bottom: var(--gap-section)">
    <header class="reveal" style="margin-bottom: 64px; max-width: 720px">
      <div class="eyebrow" style="margin-bottom: 18px">Co zyskujesz</div>
      <h2 class="profile-h" style="margin: 0">Trzy powody, dla których warto.</h2>
    </header>
    <div class="pt-grid reveal-stagger" style="grid-template-columns: repeat(3, 1fr)">
      {usp.map((u) => (
        <div class="pt-step">
          <div class="pt-n mono">{u.n}</div>
          <h3 class="pt-l display">{u.title}</h3>
          <p class="pt-d">{u.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Partners -->
  <section class="profile">
    <div class="container">
      <header class="reveal" style="margin-bottom: 48px; max-width: 720px">
        <div class="eyebrow" style="margin-bottom: 18px">Z kim współpracujemy</div>
        <h2 class="profile-h" style="margin: 0">Nasze produkty są między innymi tu.</h2>
        <p class="profile-intro" style="margin-top: 18px">Lista fragmentaryczna — pełną mapę punktów wysyłamy na życzenie.</p>
      </header>
      <div class="ingredients-grid reveal-stagger">
        {partners.map((p) => (
          <div class="ing-card" style="aspect-ratio: 16/10; display: flex; align-items: center; justify-content: center; text-align: center">
            <span class="display" style="font-size: 16px; color: var(--color-muted); font-weight: 500">{p}</span>
          </div>
        ))}
      </div>
      <p style="margin-top: 24px; font-size: 12px; color: var(--color-muted); font-family: var(--font-mono)">Placeholdery — podmień nazwy/logotypy w CMS-ie.</p>
    </div>
  </section>

  <!-- Cennik -->
  <section id="cennik" class="container" style="padding-top: var(--gap-section); padding-bottom: var(--gap-section)">
    <header class="reveal" style="max-width: 600px; margin: 0 auto 48px; text-align: center">
      <div class="eyebrow" style="margin-bottom: 18px">Cennik B2B</div>
      <h2 class="display" style="font-size: clamp(32px, 4vw, 56px); margin: 0 0 24px">
        Pobierz cennik mailem.
      </h2>
      <p style="color: var(--color-ink-soft); margin: 0">Wysyłamy po krótkiej weryfikacji. Podaj firmowy adres e-mail i nazwę działalności.</p>
    </header>
    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      class="reveal"
      style="display: flex; flex-direction: column; gap: 14px; max-width: 480px; margin: 0 auto"
    >
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="subject" value="[Gary Wrotka B2B] Prośba o cennik" />
      <input type="hidden" name="from_name" value="Gary Wrotka — B2B" />
      <input type="hidden" name="tag" value="b2b_cennik" />
      <input type="text" name="botcheck" tabindex="-1" autocomplete="off" style="display: none"/>

      <label style="display: flex; flex-direction: column; gap: 6px">
        <span class="eyebrow">E-mail firmowy *</span>
        <input type="email" name="email" required style="padding: 14px 16px; background: var(--color-paper-warm); border: 1px solid var(--color-line); border-radius: 4px; font: inherit"/>
      </label>
      <label style="display: flex; flex-direction: column; gap: 6px">
        <span class="eyebrow">Nazwa firmy *</span>
        <input type="text" name="company" required style="padding: 14px 16px; background: var(--color-paper-warm); border: 1px solid var(--color-line); border-radius: 4px; font: inherit"/>
      </label>
      <input type="hidden" name="redirect" value={new URL('/b2b?cennik=ok', Astro.url).toString()} />
      <button type="submit" class="magnetic btn-primary" style="margin-top: 8px; align-self: center">
        <span>Wyślij prośbę</span>
        <span class="arrow">→</span>
      </button>
    </form>
  </section>

  <!-- Pełny formularz B2B -->
  <section id="kontakt-b2b" class="b2b-section" data-nav-theme="dark">
    <div class="container b2b-inner">
      <header class="reveal" style="max-width: 720px; margin: 0 auto 48px; text-align: center">
        <div class="eyebrow b2b-eyebrow">Współpraca długoterminowa</div>
        <h2 class="b2b-h display" style="font-size: clamp(36px, 4.4vw, 60px)">
          Porozmawiajmy.<br/>
          <span class="b2b-accent">Odpiszemy w 24h.</span>
        </h2>
      </header>
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="reveal"
        style="display: flex; flex-direction: column; gap: 14px; max-width: 640px; margin: 0 auto"
      >
        <input type="hidden" name="access_key" value={web3formsKey} />
        <input type="hidden" name="subject" value="[Gary Wrotka B2B] Zapytanie o współpracę" />
        <input type="hidden" name="from_name" value="Gary Wrotka — B2B" />
        <input type="hidden" name="tag" value="b2b_kontakt" />
        <input type="text" name="botcheck" tabindex="-1" autocomplete="off" style="display: none"/>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px">
          <label style="display: flex; flex-direction: column; gap: 6px">
            <span class="eyebrow" style="color: rgba(244,241,234,0.55)">Imię i nazwisko *</span>
            <input type="text" name="name" required style="padding: 14px 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: 4px; color: #fafaf7; font: inherit"/>
          </label>
          <label style="display: flex; flex-direction: column; gap: 6px">
            <span class="eyebrow" style="color: rgba(244,241,234,0.55)">Firma *</span>
            <input type="text" name="company" required style="padding: 14px 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: 4px; color: #fafaf7; font: inherit"/>
          </label>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px">
          <label style="display: flex; flex-direction: column; gap: 6px">
            <span class="eyebrow" style="color: rgba(244,241,234,0.55)">NIP</span>
            <input type="text" name="nip" style="padding: 14px 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: 4px; color: #fafaf7; font: inherit"/>
          </label>
          <label style="display: flex; flex-direction: column; gap: 6px">
            <span class="eyebrow" style="color: rgba(244,241,234,0.55)">Miasto *</span>
            <input type="text" name="city" required style="padding: 14px 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: 4px; color: #fafaf7; font: inherit"/>
          </label>
        </div>
        <label style="display: flex; flex-direction: column; gap: 6px">
          <span class="eyebrow" style="color: rgba(244,241,234,0.55)">E-mail *</span>
          <input type="email" name="email" required style="padding: 14px 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: 4px; color: #fafaf7; font: inherit"/>
        </label>
        <label style="display: flex; flex-direction: column; gap: 6px">
          <span class="eyebrow" style="color: rgba(244,241,234,0.55)">Szacowany wolumen miesięczny</span>
          <select name="volume" style="padding: 14px 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: 4px; color: #fafaf7; font: inherit">
            <option>do 50 butelek / mies</option>
            <option>50–200 butelek / mies</option>
            <option>200–500 butelek / mies</option>
            <option>500+ / event jednorazowy</option>
          </select>
        </label>
        <label style="display: flex; flex-direction: column; gap: 6px">
          <span class="eyebrow" style="color: rgba(244,241,234,0.55)">Wiadomość</span>
          <textarea name="message" rows="4" style="padding: 14px 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: 4px; color: #fafaf7; font: inherit; resize: vertical"></textarea>
        </label>
        <input type="hidden" name="redirect" value={new URL('/b2b?wspolpraca=ok', Astro.url).toString()} />
        <button type="submit" class="magnetic btn-primary btn-primary-light" style="margin-top: 12px; align-self: center">
          <span>Wyślij zapytanie hurtowe</span>
          <span class="arrow">→</span>
        </button>
      </form>
    </div>
  </section>
</Layout>
