---
import Layout from '../layouts/Layout.astro';

const galleryImages = [
  '/images/photos/_DSC4577a.jpg',
  '/images/photos/_DSC4975.jpg',
  '/images/photos/fermento-nero-2.jpg',
  '/images/photos/process.jpg',
];
---
<Layout
  title="Manifest — Gary Wrotka"
  description="Historia marki: od fotografii rzemiosła do fermentów. Jak fotograf zaczął robić kombuchę."
>
  <section class="container">
    <div class="breadcrumb">
      <a href="/">Start</a>
      <span class="sep">/</span>
      <span style="color: var(--color-ink)">Manifest</span>
    </div>

    <header class="reveal" style="padding-bottom: clamp(56px, 7vw, 96px); max-width: 880px">
      <div class="eyebrow" style="margin-bottom: 18px">Manifest</div>
      <h1 class="display" style="font-size: clamp(48px, 6vw, 88px); margin: 0 0 24px; line-height: 1">
        Od fotografii<br/>rzemiosła<br/>do fermentów.
      </h1>
      <p style="font-size: 19px; line-height: 1.6; color: var(--color-ink-soft); max-width: 620px; margin: 0">
        Studio Wro od 2018 roku robi zdjęcia jedzeniu, ludziom, miejscom.
        Najczęściej tym, którzy z pasją robią coś własnymi rękami — piekarniom, browarom, manufakturom.
      </p>
    </header>
  </section>

  <section class="container story" style="padding-top: 0">
    <div class="story-text reveal-left">
      <div class="eyebrow story-eyebrow">Jak to się zaczęło</div>
      <h2 class="story-h">Z amatorskiego eksperymentu wyszły pierwsze butelki.</h2>
      <p class="story-p">
        Z czasem zaczęliśmy fermentować w domu — najpierw kapustę, potem kombuchę,
        potem coraz dziwniejsze rzeczy. Z amatorskiego eksperymentu wyszła pierwsza partia
        butelek z naklejką, kuratorską edycja smaków, kilka skrzynek dla znajomych restauracji.
      </p>
      <p class="story-p">
        <strong>Gary Wrotka</strong> to ta sama dbałość o detal, ten sam szacunek do procesu,
        ale w innym medium. Zamiast aparatu — butelka. Zamiast światła — czas.
      </p>
    </div>
    <div class="story-media reveal-clip">
      <img src={galleryImages[0]} alt="Słój fermentacyjny" loading="lazy" class="fade-img"/>
      <div class="caption">Studio · Nowy Sącz · 2025</div>
    </div>
  </section>

  <section class="profile" style="border-top: 1px solid var(--color-line); border-bottom: 0">
    <div class="container">
      <div class="reveal-left" style="max-width: 720px; margin: 0 auto; text-align: center">
        <div class="eyebrow" style="margin-bottom: 18px">Filozofia</div>
        <h2 class="profile-h" style="font-size: clamp(36px, 4.4vw, 60px)">
          Nie skalujemy się.<br/>
          <span style="font-style: italic; font-weight: 500; color: var(--color-accent)">Robimy edycje 50–300 butelek.</span>
        </h2>
        <p style="margin-top: 24px; color: var(--color-ink-soft); font-size: 17px; line-height: 1.7">
          Każda butelka jest numerowana. Każdy słoik — datowany. Nasze SCOBY mają imiona.
          Kiedy się skończy partia, robimy następną. Lub nie.
          Niektóre wariacje były zbyt dobre, żeby je powtarzać.
        </p>
      </div>
    </div>
  </section>

  <section class="container ingredients" style="padding-bottom: var(--gap-section)">
    <div class="ingredients-head reveal">
      <h2 class="ing-h">Z warsztatu <span class="accent">— okiem fotografa</span></h2>
    </div>
    <div class="grid-gallery" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px">
      {galleryImages.map((src) => (
        <div style="border: 0; padding: 0; aspect-ratio: 4/5; overflow: hidden; border-radius: 4px">
          <img src={src} alt="" loading="lazy" class="fade-img" style="width: 100%; height: 100%; object-fit: cover; transition: transform 1s ease;"/>
        </div>
      ))}
    </div>
  </section>

  <section class="b2b-section" data-nav-theme="dark" style="padding: clamp(60px, 8vw, 100px) 0">
    <div class="container b2b-inner reveal" style="max-width: 780px; text-align: center; margin: 0 auto">
      <div class="eyebrow b2b-eyebrow" style="margin-bottom: 20px">Co dalej</div>
      <h2 class="b2b-h display" style="font-size: clamp(32px, 4vw, 52px); margin: 0 0 24px">
        Cieszymy się, że tu jesteś.<br/>
        <span class="b2b-accent">Zajrzyj do katalogu albo napisz.</span>
      </h2>
      <div class="b2b-cta" style="justify-content: center">
        <a href="/katalog" class="magnetic btn-primary btn-primary-light">
          <span>Zobacz katalog</span>
          <span class="arrow">→</span>
        </a>
        <a href="/kontakt" class="btn-ghost btn-ghost-light">Napisz do nas</a>
      </div>
    </div>
  </section>
</Layout>
