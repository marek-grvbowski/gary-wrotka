---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import AddToInquiryButton from '../../components/AddToInquiryButton.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p) => ({ params: { slug: p.id }, props: { product: p } }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const related = (await getCollection('products', (p) =>
  p.data.category === product.data.category && p.id !== product.id && p.data.available
)).slice(0, 3);

const catLabel = product.data.categoryLabel ?? { kombucha: 'Kombucha', sos: 'Sos fermentowany', ocet: 'Ocet' }[product.data.category];

const hasRichData = product.data.flavorProfile.length > 0;
---
<Layout
  title={product.data.metaTitle ?? `${product.data.name} — Gary Wrotka`}
  description={product.data.metaDescription ?? product.data.shortDescription}
  ogImage={product.data.images[0]}
>
  <section class="container">
    <div class="breadcrumb">
      <a href="/katalog">Katalog</a>
      <span class="sep">/</span>
      <a href={`/katalog?cat=${product.data.category}`}>{catLabel}</a>
      <span class="sep">/</span>
      <span style="color: var(--color-ink)">{product.data.name}</span>
    </div>

    <!-- HERO ─────────────────────────────────────────────────── -->
    <div class="hero-product">
      <div class="hero-media reveal-blur" data-product-gallery>
        <img src={product.data.images[0]} alt={product.data.name} class="ken-burns fade-img" data-gallery-main/>
        {product.data.edition && <div class="ed-tag">{product.data.edition}</div>}
        {product.data.images.length > 1 && (
          <div class="hero-thumbs">
            {product.data.images.map((src, i) => (
              <button class={i === 0 ? 'active' : ''} data-thumb={i} aria-label={`Zdjęcie ${i + 1}`}>
                <img src={src} alt=""/>
              </button>
            ))}
          </div>
        )}
        <div class="photo-no" data-photo-no>N°01 / {String(product.data.images.length).padStart(2, '0')}</div>
      </div>

      <div class="hero-info">
        <div class="hero-meta-row">
          <span class="eyebrow">{catLabel}</span>
          <span class="dot"></span>
          <span class="eyebrow">{product.data.volume}</span>
          {product.data.available && (
            <>
              <span class="dot"></span>
              <span class="eyebrow" style="color: var(--color-accent)">● W magazynie</span>
            </>
          )}
        </div>

        <h1 class="hero-title display">
          {product.data.name.split(' ').map((word, i) => (
            <Fragment><span class="split-word" style={`--d: ${100 + i * 80}ms`}><span>{word}</span></span>{' '}</Fragment>
          ))}
        </h1>

        <div class="hero-flavor">{product.data.flavor}</div>

        <p class="hero-desc reveal">{product.data.shortDescription}</p>

        {product.data.badges.length > 0 && (
          <div class="badges reveal">
            {product.data.badges.map((b) => <span class="badge">{b}</span>)}
          </div>
        )}

        <div class="actions reveal">
          {product.data.available ? (
            <AddToInquiryButton
              slug={product.id}
              name={product.data.name}
              flavor={product.data.flavor}
              volume={product.data.volume}
              image={product.data.images[0]}
            />
          ) : (
            <div class="badge">Aktualnie niedostępne</div>
          )}
        </div>

        {product.data.specs.length > 0 && (
          <div class="spec-list reveal">
            {product.data.specs.map((s) => (
              <div class="spec">
                <span class="k">{s.k}</span>
                <span class="v">{s.v}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  {product.data.story && (
    <section class="container story">
      <div class="story-text reveal-left">
        <div class="eyebrow story-eyebrow">{product.data.story.eyebrow}</div>
        <h2 class="story-h">{product.data.story.title}</h2>
        {product.data.story.paragraphs.map((p) => <p class="story-p">{p}</p>)}
      </div>
      <div class="story-media reveal-clip">
        <img src={product.data.story.image} alt="" loading="lazy" class="fade-img"/>
        {product.data.story.caption && <div class="caption">{product.data.story.caption}</div>}
      </div>
    </section>
  )}

  {hasRichData && (
    <section class="profile">
      <div class="container profile-grid">
        <div class="reveal-left">
          <div class="eyebrow" style="margin-bottom: 18px">Profil smaku</div>
          <h2 class="profile-h">Wytrawna,<br/><span style="font-style: italic; font-weight: 500; color: var(--color-accent)">korzenna w finiszu.</span></h2>
          <p class="profile-intro">Tak smakuje nasza partia {product.data.name} — mierzona w skali 1–10.</p>
        </div>
        <div class="profile-list">
          {product.data.flavorProfile.map((p, i) => (
            <div class="profile-bar reveal" style={`--w: ${p.value * 10}%; transition-delay: ${i * 80}ms`}>
              <div class="label">{p.label}</div>
              <div class="track">
                <div class="ticks">
                  {Array.from({ length: 11 }).map(() => <span></span>)}
                </div>
                <div class="fill" style={`transition-delay: ${i * 120}ms`}></div>
              </div>
              <div class="val">{p.value}/10</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {product.data.detailedIngredients.length > 0 && (
    <section class="container ingredients">
      <div class="ingredients-head reveal">
        <h2 class="ing-h">Skład <span class="accent">— {product.data.detailedIngredients.length} rzeczy, nic więcej</span></h2>
        <div class="eyebrow" style="max-width: 280px; text-align: right">
          Każdy składnik z pełnym pochodzeniem.
        </div>
      </div>
      <div class="ingredients-grid reveal-stagger">
        {product.data.detailedIngredients.map((ing, i) => (
          <div class="ing-card">
            <span class="num">N°{String(i + 1).padStart(2, '0')}</span>
            <h3 class="name">{ing.name}</h3>
            <div class="note">{ing.note}</div>
            <svg class="glyph" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4">
              <line x1="7" y1="1" x2="7" y2="13"/>
              <line x1="1" y1="7" x2="13" y2="7"/>
            </svg>
          </div>
        ))}
      </div>
    </section>
  )}

  {product.data.process.length > 0 && (
    <section class="process-timeline">
      <div class="container">
        <div class="process-head reveal">
          <div>
            <div class="eyebrow" style="margin-bottom: 18px">Jak powstaje</div>
            <h2 class="profile-h" style="margin: 0">{product.data.process.length} kroki, w naszym studio.</h2>
          </div>
          <div class="eyebrow" style="max-width: 320px">
            Wszystko ręcznie, w studio przy ul. Przykładowej 1, Nowy Sącz.
          </div>
        </div>
        <div class="process-grid reveal-stagger">
          {product.data.process.map((s, i) => (
            <div class="step">
              <div class="marker">{String(i + 1).padStart(2, '0')}</div>
              <div class="duration">{s.duration}</div>
              <h3 class="label">{s.label}</h3>
              <p class="desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="container" style="padding-top: 32px; padding-bottom: 32px">
    <div class="prose-custom" style="max-width: 720px; margin: 0 auto" id="product-body">
      <Content />
    </div>
  </section>

  {related.length > 0 && (
    <section class="container related">
      <div class="related-head reveal">
        <div>
          <div class="eyebrow" style="margin-bottom: 18px">Może spodoba Ci się też</div>
          <h2 class="profile-h" style="margin: 0">Z tej samej kategorii.</h2>
        </div>
        <a href="/katalog" class="btn-ghost">Cały katalog <span>→</span></a>
      </div>
      <div class="related-grid reveal-stagger">
        {related.map((p) => (
          <a href={`/katalog/${p.id}`} class="prod-card">
            <div class="prod-media">
              <img src={p.data.images[0]} alt={p.data.name} loading="lazy" class="fade-img"/>
            </div>
            <div class="prod-body">
              <div class="prod-cat">{p.data.categoryLabel ?? catLabel}</div>
              <h3 class="prod-name">{p.data.name}</h3>
              <div class="prod-flavor">{p.data.flavor}</div>
              <span class="prod-cta">Zobacz produkt <span class="a">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Sticky inquiry bar -->
  <div class="sticky-inquiry" data-sticky-inquiry>
    <div class="swatch"><img src={product.data.images[0]} alt=""/></div>
    <div class="info">
      <div class="nm">{product.data.name}</div>
      <div class="ml">{product.data.volume} · zapytanie</div>
    </div>
    <a href="/zamowienie" class="cta" data-open-drawer-cta>
      <span>Koszyk</span>
      <span>→</span>
    </a>
  </div>

</Layout>

<script>
  // Gallery thumbnail switching
  const main = document.querySelector<HTMLImageElement>('[data-gallery-main]');
  const photoNo = document.querySelector<HTMLElement>('[data-photo-no]');
  document.querySelectorAll<HTMLButtonElement>('[data-thumb]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = Number(btn.dataset.thumb);
      const img = btn.querySelector('img');
      if (!main || !img) return;
      main.src = img.src;
      main.classList.remove('loaded');
      requestAnimationFrame(() => main.classList.add('loaded'));
      document.querySelectorAll<HTMLButtonElement>('[data-thumb]').forEach((b, i) => b.classList.toggle('active', i === idx));
      const total = document.querySelectorAll('[data-thumb]').length;
      if (photoNo) photoNo.textContent = `N°${String(idx + 1).padStart(2, '0')} / ${String(total).padStart(2, '0')}`;
    });
  });

  // Sticky inquiry after scrolling past hero
  const sticky = document.querySelector<HTMLElement>('[data-sticky-inquiry]');
  if (sticky) {
    const onScroll = () => {
      const trigger = window.innerHeight * 0.9;
      sticky.classList.toggle('in', window.scrollY > trigger);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Open drawer from sticky CTA
  document.querySelector('[data-open-drawer-cta]')?.addEventListener('click', (e) => {
    const drawer = document.querySelector('[data-drawer]');
    if (drawer) {
      e.preventDefault();
      document.dispatchEvent(new CustomEvent('drawer:open'));
    }
  });
</script>
