---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InquiryDrawer from '../components/InquiryDrawer.astro';
import { getEntry } from 'astro:content';

const globalEntry = await getEntry('global', 'global');
const accent = globalEntry?.data.accentColor ?? '#c33366';
const accentDeep = globalEntry?.data.accentDeepColor ?? '#663366';

type Props = {
  title?: string;
  description?: string;
  headerMode?: 'dark' | 'light';
  bodyClass?: string;
  ogImage?: string;
};

const {
  title = 'Gary Wrotka — rzemieślnicze fermenty',
  description = 'Rzemieślnicza kombucha, sosy i octy fermentowane z Wrocławia. Naturalne, lokalne, bez kompromisów.',
  headerMode = 'light',
  bodyClass = '',
  ogImage = '/images/brand/logo.svg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://gary-wrotka.pages.dev').toString();
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@500;600;700;800&family=Anton&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style set:html={`:root { --color-accent: ${accent}; --color-accent-deep: ${accentDeep}; }`}></style>

    <script is:inline>
      // Apply theme before paint to avoid flash
      (function() {
        try {
          var saved = localStorage.getItem('gw-theme');
          if (!saved) {
            saved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.dataset.theme = saved;
        } catch (e) {}
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <Header initialMode={headerMode} />
    <main>
      <slot />
    </main>
    <Footer />
    <InquiryDrawer />
    <div id="gw-toast" class="gw-toast" role="status" aria-live="polite"></div>

    <script>
      import { initInquiryCart } from '../scripts/inquiry-cart';
      import { initAnimations } from '../scripts/animations';
      initInquiryCart();
      initAnimations();

      // Theme toggle binding + body sync with html dataset
      const applyTheme = (t: string) => {
        document.documentElement.dataset.theme = t;
        document.body.dataset.theme = t;
        try { localStorage.setItem('gw-theme', t); } catch (e) {}
      };
      applyTheme(document.documentElement.dataset.theme || 'light');
      document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const cur = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
          applyTheme(cur === 'dark' ? 'light' : 'dark');
        });
      });
    </script>
  </body>
</html>
