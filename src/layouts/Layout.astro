---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InquiryDrawer from '../components/InquiryDrawer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { getEntry } from 'astro:content';

const globalEntry = await getEntry('global', 'global');
const accent = globalEntry?.data.accentColor ?? '#c33366';
const accentDeep = globalEntry?.data.accentDeepColor ?? '#663366';
const ga4Id = globalEntry?.data.analytics?.ga4Id?.trim();
const bannerText = globalEntry?.data.analytics?.cookieBannerText ?? '';

type Props = {
  title?: string;
  description?: string;
  headerMode?: 'dark' | 'light';
  bodyClass?: string;
  ogImage?: string;
};

const {
  title = 'Gary Wrotka — rzemieślnicze fermenty',
  description = 'Rzemieślnicza kombucha, sosy i octy fermentowane z Nowego Sącza. Naturalne, lokalne, bez kompromisów.',
  headerMode = 'light',
  bodyClass = '',
  ogImage = '/images/brand/logo.svg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://gary-wrotka.pages.dev').toString();
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@500;600;700;800&family=Anton&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style set:html={`:root { --color-accent: ${accent}; --color-accent-deep: ${accentDeep}; }`}></style>

    <script is:inline>
      // Apply theme before paint to avoid flash
      (function() {
        try {
          var saved = localStorage.getItem('gw-theme');
          if (!saved) {
            saved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.dataset.theme = saved;
        } catch (e) {}
      })();
    </script>

    {ga4Id && (
      <Fragment>
        <script is:inline define:vars={{ ga4Id }}>
          // Google Consent Mode v2 — domyślnie wszystko denied dopóki user nie zgodzi się
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          window.gtag = gtag;
          gtag('consent', 'default', {
            'ad_storage': 'denied',
            'ad_user_data': 'denied',
            'ad_personalization': 'denied',
            'analytics_storage': 'denied',
            'wait_for_update': 500
          });
          // Jeśli user już zaakceptował, ustaw od razu
          try {
            var c = localStorage.getItem('gw-cookie-consent');
            if (c === 'granted') {
              gtag('consent', 'update', {
                'ad_storage': 'granted',
                'ad_user_data': 'granted',
                'ad_personalization': 'granted',
                'analytics_storage': 'granted'
              });
            }
          } catch (e) {}
          gtag('js', new Date());
          gtag('config', ga4Id, { anonymize_ip: true });
        </script>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
      </Fragment>
    )}
  </head>
  <body class={bodyClass}>
    <Header initialMode={headerMode} />
    <main>
      <slot />
    </main>
    <Footer />
    <InquiryDrawer />
    <CookieBanner text={bannerText} enabled={!!ga4Id} />
    <div id="gw-toast" class="gw-toast" role="status" aria-live="polite"></div>

    <script>
      import { initInquiryCart } from '../scripts/inquiry-cart';
      import { initAnimations } from '../scripts/animations';
      initInquiryCart();
      initAnimations();

      // Theme toggle binding + body sync with html dataset
      const applyTheme = (t: string) => {
        document.documentElement.dataset.theme = t;
        document.body.dataset.theme = t;
        try { localStorage.setItem('gw-theme', t); } catch (e) {}
      };
      applyTheme(document.documentElement.dataset.theme || 'light');
      document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const cur = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
          applyTheme(cur === 'dark' ? 'light' : 'dark');
        });
      });
    </script>
  </body>
</html>
